# Raw/intermediate data are downloaded or generated.
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Generated outputs.
outputs/charts/*
!outputs/charts/.gitkeep
!outputs/charts/confirmatory_forecasting_verdict.png
!outputs/charts/governed_data_architecture.png
!outputs/charts/model_ladder_chronological_validation.png
!outputs/charts/locked_test_temporal_stability.png
!outputs/charts/evidence_governance_model_boundaries.png
outputs/tables/*
!outputs/tables/.gitkeep
outputs/brief/*
!outputs/brief/.gitkeep

# Local secrets and platform state.
.env
*.token
.databricks/
*.egg-info/
.mypy_cache/
.coverage
htmlcov/
!data/raw/uci_steel_energy/
!data/raw/uci_steel_energy/**

# Large modeling artifacts are reproducible but not versioned.
outputs/modeling/*.parquet
outputs/modeling/*.joblib
outputs/modeling/*.pkl
outputs/modeling/*.onnx
outputs/modeling/*.bin
outputs/modeling/*.tmp
outputs/modeling/models/
outputs/modeling/checkpoints/

